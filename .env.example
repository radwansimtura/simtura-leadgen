# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Microsoft Azure App Registration (for Microsoft Graph / Outlook)
MS_CLIENT_ID=your-azure-app-client-id
MS_CLIENT_SECRET=your-azure-app-client-secret
MS_TENANT_ID=your-azure-tenant-id
MS_USER_EMAIL=you@yourdomain.com

# System config
OPERATOR_EMAIL=you@yourdomain.com
PORT=3000

# Base URL for unsubscribe links (no trailing slash)
BASE_URL=https://your-app.onrender.com

# Optional: override the Claude model
CLAUDE_MODEL=claude-sonnet-4-6

# Hunter.io for email finding (optional enrichment)
HUNTER_API_KEY=your-hunter-api-key
